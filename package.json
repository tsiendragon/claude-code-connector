{
  "name": "ccc",
  "version": "0.3.0",
  "description": "Manage Claude Code / Cursor sessions in tmux — CLI and Node.js library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ccc": "dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc && node scripts/fix-shebang.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=18" },
  "type": "module",
  "license": "MIT"
}
